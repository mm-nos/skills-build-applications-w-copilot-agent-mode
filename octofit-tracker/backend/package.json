{
  "name": "octofit-tracker-backend",
  "version": "1.0.0",
  "description": "OctoFit Tracker backend API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm --experimental-specifier-resolution=node src/index.ts",
    "seed": "node --loader ts-node/esm --experimental-specifier-resolution=node src/scripts/seed.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "ts-check": "tsc --noEmit"
  },
  "keywords": [
    "fitness",
    "tracker",
    "octofit"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "mongoose": "^8.3.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2"
  }
}
